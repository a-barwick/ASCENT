{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascent.local/protocol/envelopes.schema.json",
  "title": "ASCENT protocol envelopes",
  "description": "Transport envelopes shared by HTTP commands, snapshots, and ordered realtime events.",
  "x-ascent-protocol-version": "1.1.0",
  "$defs": {
    "CommandResultStatus": {
      "type": "string",
      "enum": ["accepted", "rejected", "scheduled", "committed", "failed"]
    },
    "CommandEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion",
        "commandId",
        "idempotencyKey",
        "type",
        "actorId",
        "receivedAt",
        "payload"
      ],
      "properties": {
        "protocolVersion": {
          "type": "string"
        },
        "commandId": {
          "type": "string"
        },
        "idempotencyKey": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        },
        "companyId": {
          "type": ["string", "null"]
        },
        "expectedVersion": {
          "type": ["integer", "null"]
        },
        "receivedAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "CommandResultEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "commandId", "status", "committedAt", "payload"],
      "properties": {
        "protocolVersion": {
          "type": "string"
        },
        "commandId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/CommandResultStatus"
        },
        "committedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "errorCode": {
          "type": ["string", "null"]
        },
        "safeMessage": {
          "type": ["string", "null"]
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "EventEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "sequence", "topic", "type", "occurredAt", "payload"],
      "properties": {
        "eventId": {
          "type": "string"
        },
        "commandId": {
          "type": ["string", "null"]
        },
        "protocolVersion": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "topicSequence": {
          "type": "integer",
          "minimum": 1
        },
        "topic": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "SnapshotEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "snapshotId", "topic", "sequence", "generatedAt", "payload"],
      "properties": {
        "protocolVersion": {
          "type": "string"
        },
        "snapshotId": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
